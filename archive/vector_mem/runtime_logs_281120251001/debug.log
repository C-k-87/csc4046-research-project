def find_zero(xs: list):
    """
    Finds the zero of a polynomial represented by the coefficients `xs` by
    using the bisection method to find roots in the interval [a, b].
    This function assumes that the polynomial has at least one real root.
    """
    def poly(x: float) -> float:
        return sum(coeff * x ** i for i, coeff in enumerate(xs))

    def f(x: float) -> float:
        return poly(x) - 0

    a, b = -1000, 1000
    epsilon = 1e-6

    while b - a > epsilon:
        midpoint = (a + b) / 2.0
        if f(midpoint) * f(a) < 0:
            b = midpoint
        else:
            a = midpoint

    return (a + b) / 2.0


