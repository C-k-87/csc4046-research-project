from math import sqrt


def is_prime(n):
    if n < 2:
        return False
    for i in range(2, int(sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True


def count_up_to(n):
    return [i for i in range(2, n) if is_prime(i)]

