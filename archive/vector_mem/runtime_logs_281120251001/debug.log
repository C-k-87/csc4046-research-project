def car_race_collision(n):
    cars_left_to_right = list(range(n))
    cars_right_to_left = list(range(n))[::-1]
    collisions = 0

    for left_car in cars_left_to_right:
        right_car = cars_right_to_left.pop()
        if left_car == right_car:
            collisions += 1

    return collisions
```

