import unittest

def encode(message):
    def swap_case(ch):
        return ch.upper() if ch.islower() else ch.lower()

    def replace_vowels(ch):
        vowels = "aeiouAEIOU"
        if ch in vowels:
            return chr(ord(ch) + 2)
        return ch

    return ''.join(swap_case(replace_vowels(ch)) for ch in message)

def decode(encoded):
    def reverse_string(s):
        return s[::-1]

    def find_next_vowel(s):
        vowels = "aeiouAEIOU"
        for i in range(len(s)-1, -1, -1):
            if s[i] in vowels:
                return i
        return -1

    def make_palindrome(s, start, end):
        while start < end:
            if s[start] != s[end]:
                return s[start:end]
            start += 1
            end -= 1
        return ""

    message = reverse_string(encoded)
    palindrome = make_palindrome(message, 0, len(message)-1)
    return message[:len(message)-len(palindrome)] + reverse_string(palindrome)


class TestEncoding(unittest.TestCase):

    def test_encode(self):
        self.assertEqual(encode('test'), 'TGST')
        self.assertEqual(encode('This is a message'), 'tHKS KS C MGSSCGG')

    def test_decode(self):
        self.assertEqual(decode('TGST'), 'test')
        self.assertEqual(decode('tHKS KS C MGSSCGG'), 'This is a message')

if __name__ == '__main__':
    unittest.main()
