def encode_cyclic(s: str):
    num_groups = (len(s) + 2) // 3
    if len(s) % 3 != 0:  # Adjust for strings not divisible by 3
        s += " " * (3 - len(s) % 3)
    
    groups = [s[(3 * i):min((3 * i + 3), len(s))] for i in range(num_groups)]
    groups = [(group[1:] + group[0]) if len(group) == 3 else group for group in groups]
    return "".join(groups)
```

