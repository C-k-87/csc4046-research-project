def calculate_economic_growth(gdp, population, investment, consumption, exports, imports):
    """
    Calculate the economic growth rate based on a simplified economic model.
    
    :param gdp: float - The Gross Domestic Product
    :param population: int - The total population
    :param investment: float - Total investment in the economy
    :param consumption: float - Total consumption by the population
    :param exports: float - Total value of exports
    :param imports: float - Total value of imports
    :return: float - The calculated economic growth rate
    """

    growth_rate = (gdp + investment - consumption) / (population * (exports - imports))
