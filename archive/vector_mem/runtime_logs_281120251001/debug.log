def make_palindrome(s: str) -> str:

    """

    Return the longest palindrome that can be made by appending the reverse

    of a substring to s.


    >>> make_palindrome('eabcdzzzz')

    'abcdzzzz'

    >>> make_palindrome('abcd')

    'dcbabcd'

    >>> make_palindrome('abcd')

    'd'

    >>> make_palindrome('dddddddabc')

    'dddddddabcd'

    >>> make_palindrome('dddddddabcd')

    'dddddddabcd'

    >>> make_palindrome('eabcdzzzz')

    'zzzz'

    >>> make_palindrome('dddddddabc')

    'dddddddabc'

    >>> make_palindrome('dddddddabce')

    'ddd'

    >>> make_palindrome('eabcdzzzz')

    'zzzz'

    >>> make_palindrome('dddzzzzzzzddddabc')

    'dddzzzzzzzdddbc'

    """

    longest_palindrome = ''

    for i in range(len(s)):

        for j in range(i + 1, len(s) + 1):

            substring = s[i:j]

            reversed_substring = substring[::-1]

            if substring + reversed_substring == (substring + reversed_substring)[::-1] and len(substring) > len(longest_palindrome):

                longest_palindrome = substring + reversed_substring

    return longest_palindrome

```
