            if sorted_numbers[i] == min_value:
                min_numbers.append(sorted_numbers[i])
            elif sorted_numbers[i] == max_value:
                max_numbers.append(sorted_numbers[i])
        for number in min_numbers + max_numbers:
            numbers.remove(number)
