```python
import re

def select_words(s, n):
    if not s:
        return []
    
    words = re.findall(r'\b[^\W\d_]*\b', s)
    selected_words = [word for word in words if len(re.findall(r'[bcdfghjklmnpqrstvwxyz]', word.lower())) == n]
    
    return selected_words
```
