from typing import List

def sort_third(l: List[int]):
    l_copy = l.copy()
    l_copy_third = l_copy[::3]
    l_copy_third.sort()
    
    for i in range(len(l_copy)):
        if i % 3 != 0:
            l_copy[i] = l_copy[i]
        else:
            l_copy[i] = l_copy_third.pop(0)
            
    return l_copy
