import re


def file_name_check(file_name):

    if len(re.findall(r'\d', file_name)) > 3:

        return 'No'

    if re.search(r'^\d', file_name):

        return 'No'

    match = re.match(r'^[a-zA-Z][a-zA-Z]*\.[txt|exe|dll]$', file_name)

    return 'Yes' if match else 'No'

