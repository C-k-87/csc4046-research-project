```python
from typing import List

def separate_paren_groups(paren_string: str) -> List[str]:
    result = []
    temp_group = ''
    num_open, num_close = 0, 0

    for char in paren_string:
        if char == '(':
            num_open += 1
            temp_group += char
        elif char == ')':
            num_close += 1
            temp_group += char
            if num_open == num_close:
                result.append(temp_group)
                temp_group = ''
                num_open, num_close = 0, 0
        else:
            continue

    return result
```
