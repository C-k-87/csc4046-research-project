def max_subarray_sum(arr, k):
    """
    Given an array of integers arr and an integer k, returns the maximum sum of a subarray with length at most k.
    """
    max_sum = float('-inf')
    curr_sum = 0
    window_start = 0
    for window_end in range(len(arr)):
        curr_sum += arr[window_end]
        if window_end - window_start + 1 > k:
            curr_sum -= arr[window_start]
            window_start += 1
        max_sum = max(max_sum, curr_sum)
    return max_sum

