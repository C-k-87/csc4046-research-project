def change_base(x: int, base: int):
    if not 2 <= base < 10:
        raise ValueError("Base must be between 2 and 10.")

    if x == 0:
        return "0"

    digits = "0123456789ABCDEF"
    result = ''
    while x > 0:
        result = digits[x % base] + result
        x //= base

    return result

```
