def strange_sort_list(lst):
    """
    Sorts a list in a "strange" manner:
    - If the list contains only one element, return the list.
    - If the list is empty, return an empty list.
    - For lists with more than one element, sort the list in ascending order.
    - Then, move the smallest value to the head of the list.
    - Next, move the largest value to the tail of the list.
    - Repeat the process until the list is fully sorted in the "strange" manner.
    """
    q = deque(lst)
    while len(q) > 1:
        min_val = min(q)
        max_val = max(q)
        if min_val == max_val:
            return lst
        q.remove(min_val)
        q.remove(max_val)
        q.appendleft(min_val)
        q.append(max_val)
    return lst
