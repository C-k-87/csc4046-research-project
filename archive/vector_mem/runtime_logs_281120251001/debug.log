```python
import unittest

def solve(s):
    alphabet = "abcdefghijklmnopqrstuvwxyz"
    encoded_str = ""
    i = 0
    
    while i < len(s):
        try:
            char_index = alphabet.index(s[i].lower())
        except ValueError:
            encoded_str += s[i]
        else:
            if char_index % 2 == 0:
                encoded_str += s[i].upper()
            else:
                encoded_str += s[i].lower()
        i += 1
    return encoded_str


def encode_cyclic(s, alphabet):
    encoded_str = ""
    i = 0
    while i < len(s):
        try:
            char_index = alphabet.index(s[i])
        except ValueError:
            encoded_str += s[i]
        else:
            group_start_index = char_index // 2
            encoded_str += s[i] + alphabet[group_start_index]
        i += 1
    return encoded_str


class TestSolve(unittest.TestCase):
    def test_solve(self):
        self.assertEqual(solve("1234"), "4321")
        self.assertEqual(solve("ab"), "AB")
        self.assertEqual(solve("#a@C"), "#A@c")
        self.assertEqual(solve(""), "")
        self.assertEqual(solve("A"), "a")


class TestEncodeCyclic(unittest.TestCase):
    def test_encode_cyclic(self):
        self.assertEqual(encode_cyclic("1234", "abcdefghijklmnopqrstuvwxyz"), "2543")
        self.assertEqual(encode_cyclic("ab", "abc"), "ba")
        self.assertEqual(encode_cyclic("#a@C", "abc"), "#A@C")
