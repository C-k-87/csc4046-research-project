```python

import math


def is_simple_power(x, n):
    # Check if n is 0 and x is not to avoid division by zero
    if n == 0 and x != 0:
        return False

    # Check if n is 1 and x is not 1 to avoid infinite loop
    if n == 1:
        return x == 1

    # Calculate the power using integer exponentiation
    power = int(math.log(x, n))

    # Check if the power of n is equal to x
    return n ** power == x
```
