def max_fill(grid, capacity):

    def fill_bucket(bucket, row, col):

        while 1:

            if grid[row][col] == 0:

                return bucket

            bucket -= 1

            col += 1

            if col == len(grid[row]):

                col = 0

                row += 1

                if row == len(grid):

                    return bucket


    max_fillings = 0

    for row in range(len(grid)):

        remaining = capacity

        bucket = 0

        for col in range(len(grid[row])):

            if grid[row][col] == 1:

                bucket += fill_bucket(bucket, row, col)

                if bucket > remaining:

                    max_fillings += remaining

                    remaining = bucket % capacity

                else:

                    remaining -= bucket

    return max_fillings


