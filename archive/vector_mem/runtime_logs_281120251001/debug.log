```python
from typing import List

def get_odd_collatz(n: int) -> List[int]:
    collatz_seq = []
    while n != 1:
        collatz_seq.append(n)
        if n % 2 == 0:
            n = n // 2
        else:
            n = 3*n + 1
    if n == 1:
        collatz_seq.append(n)
    return [x for x in collatz_seq if x % 2 != 0]
```
