from collections import deque

def match_parens(lst):
    stack = deque()
    parens_pairs = {
        '(': ')',
        '[': ']',
        '{': '}'
    }

    for s in lst:
        if s in parens_pairs:
            stack.append(s)
        elif s in parens_pairs.values():
            if not stack or parens_pairs[stack.pop()] != s:
                return 'No'

    return 'Yes' if not stack else 'No'

