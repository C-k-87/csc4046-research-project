from collections import Counter

def find_max(words):
    max_unique_count = 0
    max_word = ""

    for word in words:
        unique_char_count = len(set(word))
        if unique_char_count > max_unique_count or (unique_char_count == max_unique_count and word < max_word):
            max_unique_count = unique_char_count
            max_word = word

    return max_word
```
