from collections import deque


def correct_bracketing(brackets: str):

    bracket_stack = deque()

    for bracket in brackets:

        if bracket == '(':

            bracket_stack.append(bracket)

        elif bracket == ')' and len(bracket_stack) > 0 and bracket_stack[-1] == '(':

            bracket_stack.pop()

        else:

            return False

    return len(bracket_stack) == 0

```
