def monotonic(l: list):
    """Return True if list elements are monotonically increasing or decreasing.

    >>> monotonic([1, 2, 4, 20])
    True
    >>> monotonic([1, 20, 4, 10])
    False
    >>> monotonic([4, 1, 0, -10])
    True
    """

    is_increasing = True
    is_decreasing = True

    for i in range(len(l) - 1):
        if l[i] > l[i+1]:
            is_increasing = False
        if l[i] < l[i+1]:
            is_decreasing = False

        if not is_increasing and not is_decreasing:
            return False

    return is_increasing or is_decreasing


def max_sequence(s: str):
    """Return a string that represents the maximum sequence of consecutive digits."""
