from typing import List


def sort_numbers(numbers: str) -> str:

    number_map = {

        'zero': 0, 'one': 1, 'two': 2, 'three': 3, 'four': 4,

        'five': 5, 'six': 6, 'seven': 7, 'eight': 8, 'nine': 9

    CV = {v: k for k, v in number_map.items()}


    max_numbers = []

    for i, number in enumerate(numbers.split()):

        max_count = 1

        max_numbers.append(max(numbers[:i + 1]))


        for j in range(1, i + 1):

            if numbers[i - j] == numbers[i + 1 - j] and numbers[i - j] != ' ':

                count = j

                while numbers[i - count] == numbers[i + 1 - count] and count > 0:

                    count -= 1

                if count > max_count:

                    max_count = count

                    max_numbers[i] = max_numbers[i] + max_count * ' ' + CV[numbers[i]]

    return ' '.join(max_numbers)

```
