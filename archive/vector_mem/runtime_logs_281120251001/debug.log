def count_nums(nums, threshold):
    """Given a list of integers `nums`, count how many integers have a digit sum
    equal to or greater than the given `threshold`
    """
    def sum_of_digits(num):
        total = 0
        while num > 0:
            total += num % 10
            num //= 10
        return total

    counter = Counter()
    for num in nums:
        digit_sum = sum_of_digits(num)
        if digit_sum >= threshold:
            counter[num] += 1
    return sum(1 for count in counter.most_common() if count[1] >= threshold)

