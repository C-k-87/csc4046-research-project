def is_cube(num):
    """
    Check if a number is a perfect cube.
    """
    return num >= 0 and round(num ** (1/3)) ** 3 == num

def sum_of_digits(num):
    """
    Calculate the sum of digits of a number.
    """
    return sum(int(digit) for digit in str(abs(num)))

def count_nums(lst):
    """
    Count numbers in a list that have a non-zero digit sum.
    """
    return sum(1 for num in lst if sum_of_digits(num) > 0)

def double_the_difference(lst):
    """
    Given a list of numbers, return double the sum of squares of the numbers
    in the list that are odd. Ignore numbers that are negative or not integers.
    """
    return sum(num ** 2 for num in lst if num > 0 and num % 2 != 0) * 2
