```python
import math

def circular_shift(x, shift):
    if x == 0:
        return "0"
    if shift < 0:
        shift = math.ceil(shift / 2) * 2 + 1
    elif shift == 0:
        return str(x)
    else:
        x_str = str(x)
        shift %= len(x_str)
        return x_str[-shift:] + x_str[:-shift]
```
