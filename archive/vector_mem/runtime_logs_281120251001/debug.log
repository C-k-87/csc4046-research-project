from functools import reduce


def prod_signs(arr):
    if not arr:
        return None
    product_signs = reduce(lambda x, y: x * y, [1 if i > 0 else -1 if i < 0 else 0 for i in arr])
    return sum(abs(i) * product_signs for i in arr)
