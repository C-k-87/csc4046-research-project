import math
from collections import Counter

def max_fill(grid, capacity):
    rows, cols = len(grid), len(grid[0])
    fillings = 0
    for row in grid:
        counts = Counter(row)
        max_count = max(counts.values(), default=0)
        if max_count <= capacity:
            fillings += 1
        else:
            max_fillings = sum(count // capacity for count in counts.values())
            fillings += max_fillings
    return fillings
```
