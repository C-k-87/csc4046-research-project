from typing import List


def monotonic(l: List[int]) -> bool:
    is_increasing = True
    is_decreasing = True
    
    for i in range(len(l) - 1):
        if l[i] < l[i + 1]:
            is_decreasing = False
        elif l[i] > l[i + 1]:
            is_increasing = False
        else:
            is_increasing = False
            is_decreasing = False
            
        if not is_increasing and not is_decreasing:
            return False

    return is_increasing or is_decreasing
