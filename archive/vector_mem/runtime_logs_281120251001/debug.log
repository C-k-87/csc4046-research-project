from functools import cmp_to_key

def int_to_mini_roman(number):
    if not 1 <= number <= 1000:
        raise ValueError("Number must be in the range 1 to 1000")

    value_map = {1000: 'm', 900: 'cm', 500: 'd', 400: 'cd', 100: 'c', 90: 'xc', 50: 'l', 40: 'xl', 10: 'i', 9: 'ix', 5: 'v', 4: 'iv', 1: 'i'}

    def compare(a, b):
        a, b = value_map[a], value_map[b]
        if a == b:
            return 0
        elif a > b:
            return -1
        else:
            return 1

    roman_numeral = ''
    sorted_values = sorted(value_map.keys(), key=cmp_to_key(compare), reverse=True)
    for value in sorted_values:
        while number >= value:
            number -= value
            roman_numeral += value_map[value]
    return roman_numeral
```
