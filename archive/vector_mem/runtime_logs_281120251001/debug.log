def fib4(n: int) -> int:

    memo = {0: 0, 1: 0, 2: 2, 3: 0}

    def compute(x: int) -> int:

        if x in memo:

            return memo[x]

        memo[x] = compute(x - 1) + compute(x - 2) + compute(x - 3) + compute(x - 4)

        return memo[x]

    return compute(n)

```
