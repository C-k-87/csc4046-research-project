def parse_nested_parens(s: str) -> list:
    result = []
    current_level = 0
    for char in s:
        if char == '(':
            if current_level == 0:
                result.append(current_level)
            current_level += 1
        elif char == ')':
            if current_level > 0:
                current_level -= 1
                if current_level == 0:
                    result.append(current_level)
            else:
                raise ValueError("Unbalanced parentheses")
    return result


def unique(l: list):
    from collections import OrderedDict

    seen = OrderedDict.fromkeys(l)

    return sorted(seen, key=seen.get)
