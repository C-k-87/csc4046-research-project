def make_a_pile(n):
    if n <= 0:
        raise ValueError("n must be a positive integer")

    stone_pile = []
    current_level = n

    while current_level > 0:
        if n % 2 == 0:
            current_level -= 1
            stone_pile.append(current_level + 1)
        else:
            current_level -= 1
            stone_pile.append(current_level + 2)

    stone_pile = stone_pile[::-1]
    return stone_pile
```
