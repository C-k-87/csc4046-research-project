from collections import defaultdict

def by_length(arr):
    digit_names = {
        '0': 'Zero',
        '1': 'One',
        '2': 'Two',
        '3': 'Three',
        '4': 'Four',
        '5': 'Five',
        '6': 'Six',
        '7': 'Seven',
        '8': 'Eight',
        '9': 'Nine'
    }

    valid_numbers = [str(num) for num in arr if 1 <= num <= 9]
    valid_numbers.sort(reverse=True)
    
    names_of_numbers = [digit_names[num] for num in valid_numbers]
    return names_of_numbers
