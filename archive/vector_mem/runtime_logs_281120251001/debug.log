```python
def f(n):
    from math import factorial
    from functools import reduce

    def even_factorial(i):
        return factorial(i) if i % 2 == 0 else 0

    def sum_from_1_to_i(i):
        return reduce(lambda x, y: x + y, range(1, i+1))

    return [even_factorial(i) if i % 2 == 0 else sum_from_1_to_i(i) for i in range(1, n+1)]
```
