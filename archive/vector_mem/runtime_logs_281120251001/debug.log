def numerical_letter_grade(grades):
    letter_grades = []

    for grade in grades:
        if grade == 4.0:
            letter_grades.append('A+')
        elif grade > 4.0 and grade <= 3.7:
            letter_grades.append('A')
        elif grade > 3.7 and grade <= 3.3:
            letter_grades.append('A-')
        elif grade > 3.3 and grade <= 3.0:
