    """Return the median of elements in the list l."""

    if not l:

        raise ValueError("The input list is empty.")


    l = sorted(l)


    n = len(l)

    m = n - 1


    if n % 2 == 1:

        return l[n // 2]

    else:

        return (l[int((m / 2))] + l[int((m / 2) + 1)]) / 2.0

