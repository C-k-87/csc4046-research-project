from math import floor, ceil


def closest_integer(value):

    num = float(value)

    if num == int(num):

        return int(num)

    if num > 0:

        return ceil(num) if num - int(num) >= 0.5 else int(num)

    else:

        return floor(num) if num - int(num) <= -0.5 else int(num)

```
