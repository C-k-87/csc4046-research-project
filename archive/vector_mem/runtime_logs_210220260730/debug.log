```python
from collections import Counter

def even_odd_palindrome(n):
    palindromes = set()
    for i in range(1, n + 1):
        if str(i) == str(i)[::-1]:
            palindromes.add(i)
    even_count = sum(1 for i in palindromes if i % 2 == 0)
    odd_count = len(palindromes) - even_count
    return even_count, odd_count
```
