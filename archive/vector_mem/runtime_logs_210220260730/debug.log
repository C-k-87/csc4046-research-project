from math import sqrt


def is_prime(num: int) -> bool:
    if num <= 1:
        return False
    for i in range(2, int(sqrt(num)) + 1):
        if num % i == 0:
            return False
    return True


def fib(n: int) -> int:
    a, b = 0, 1
    for _ in range(n):
        a, b = b, a + b
    return a


def prime_fib(n: int) -> int:
    i = 1
    count = 0
    while True:
        fib_num = fib(i)
        if is_prime(fib_num):
            count += 1
            if count == n:
                return fib_num
        i += 1
```
