from collections import Counter

def find_max(words):
    max_word = ""
    max_count = 0
    for word in words:
        unique_chars = len(Counter(word))
        if unique_chars > max_count or (unique_chars == max_count and word < max_word):
            max_word = word
            max_count = unique_chars
    return max_word
```
