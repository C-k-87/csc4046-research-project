from typing import List

def move_one_ball(arr: List[int]) -> bool:
    if not arr:
        return True

    min_val = float('inf')
    max_val = float('-inf')

    for num in arr:
        if num < min_val:
            min_val = num
        if num > max_val:
            max_val = num

    return max_val - min_val <= len(arr) - 1
```
