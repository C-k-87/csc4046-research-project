```python
from typing import List

def sort_numbers(numbers: str) -> str:
    valid_numbers = ['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine']
    
    # Validate input format
    if not all(num_str in valid_numbers for num_str in numbers.split()):
        raise ValueError("Input does not match the expected format")
    
    # Convert numbers to integers and sort
    sorted_numbers = sorted(map(lambda x: valid_numbers.index(x), numbers.split()), key=int)
    
    # Convert back to string and join
    return ' '.join(map(str, sorted_numbers))
