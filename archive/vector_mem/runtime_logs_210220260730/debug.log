from typing import Union


def circular_shift(x: int, shift: int) -> str:

    if x == 0:

        return '0'


    sign = -1 if x < 0 else 1

    x *= sign

    x_str = str(abs(x))

    shift %= len(x_str)

    shifted_str = x_str[-shift:] + x_str[:-shift]


    return str(sign * int(shifted_str))

```
