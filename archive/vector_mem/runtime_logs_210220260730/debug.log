from collections import deque

def match_parens(lst):
    if len(lst) != 2 or not all(isinstance(s, str) for s in lst):
        return 'No'
    
    left_stack = deque()
    right_stack = deque()

    for char in lst[0]:
        if char == '(':
            left_stack.append(char)
        else:
            if not left_stack or left_stack.pop() != '(':
                return 'No'

    for char in lst[1]:
        if char == ')':
            if not right_stack or right_stack.pop() != '(':
                return 'No'
        else:
            if not right_stack:
                left_stack.append(char)

    return 'Yes' if not left_stack and not right_stack else 'No'
