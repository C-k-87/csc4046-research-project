```python
from typing import List

def move_one_ball(arr: List[int]) -> bool:
    if not arr:
        return True

    n = len(arr)
    sorted_arr = sorted(arr)

    if arr == sorted_arr:
        return True

    left, right = 0, n - 1

    while left <= right:
        mid = left + (right - left) // 2

        if sorted_arr[mid] == arr[mid]:
            return True
        elif sorted_arr[mid] < arr[mid]:
            left = mid + 1
        else:
            right = mid - 1

    return False
```
