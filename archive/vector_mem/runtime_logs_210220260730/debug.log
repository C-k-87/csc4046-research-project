def make_a_pile(n):
    if n <= 0:
        return []
    
    pile = []
    stones = n
    while stones > 0:
        pile.append(stones)
        if n % 2 == 0:
            stones += 2
        else:
            stones += 2 if stones % 2 == 1 else 1
        n -= 1

    return pile
