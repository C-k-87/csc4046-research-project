from typing import List

def parse_music(music_string: str) -> List[int]:
    beats = []
    music_parts = music_string.split()
    for part in music_parts:
        if part == 'o':
            beats.append(4)
        elif part == 'o|':
            beats.append(2)
        elif part == '.|':
            beats.append(1)
    return beats
```
