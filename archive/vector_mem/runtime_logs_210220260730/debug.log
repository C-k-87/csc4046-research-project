def words_string(s):

    if not s:

        return []


    words = []

    word_start = 0

    for i, char in enumerate(s):

        if char.isspace() or char == ',':

            if i:

                words.append(s[word_start:i].strip())

                word_start = i + 1


    if word_start < len(s):

        words.append(s[word_start:].strip())


    return words

