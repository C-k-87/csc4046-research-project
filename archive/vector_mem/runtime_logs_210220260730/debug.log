def anti_shuffle(s):
    if not isinstance(s, str):
        raise TypeError("Input must be a string")

    def sort_word(word):
        return ''.join(sorted(word))

    words = s.split()
    sorted_words = [sort_word(word) for word in words]
    return ' '.join(sorted_words)
