def smallest_change(arr):
    from collections import deque

    def is_palindrome(sub_arr):
        return sub_arr == sub_arr[::-1]

    def get_longest_palindromic_subarray(arr):
        dq = deque()
        for i in range(len(arr)):
            if i > 0 and arr[i] == arr[i - 1]:
                dq.append(arr[i])
            else:
                dq = deque([arr[i]])

            if is_palindrome(list(dq)):
                return dq
        return None

    longest_palindromic_subarray = get_longest_palindromic_subarray(arr)
    if longest_palindromic_subarray is None:
        return len(arr) - 1

    changes_needed = 0
    for i in range(len(arr)):
        if arr[i] != longest_palindromic_subarray[i]:
            changes_needed += 1

    return changes_needed
