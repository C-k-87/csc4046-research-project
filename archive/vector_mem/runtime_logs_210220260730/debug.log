import string


def encode(message):

    if not isinstance(message, str):

        raise TypeError("Input must be a string")


    result = []

    for char in message:

        if char.isalpha():

            swap_case = char.upper() if char.islower() else char.lower()

            if char.lower() in 'aeiou':

                new_char = swap_case

                if swap_case.lower() == 'y':

                    new_char = 'a'

                else:

                    new_char = chr(ord(swap_case) + 2)

                if new_char not in string.ascii_letters:

                    raise ValueError("New character is not a letter")

            result.append(new_char)

        else:

            raise ValueError("Only letters are allowed")

    return ''.join(result)

