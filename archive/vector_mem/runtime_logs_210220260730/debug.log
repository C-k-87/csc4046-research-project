from typing import List

def monotonic(l: List[int]) -> bool:
    increasing = decreasing = True
    for i in range(len(l) - 1):
        if l[i] > l[i + 1]:
            increasing = False
        if l[i] < l[i + 1]:
            decreasing = False
        if not increasing and not decreasing:
            return False
    return True
```

(Note: This function assumes that the input list can have any number of elements and doesn't include checking for empty lists or lists with a single element.)
