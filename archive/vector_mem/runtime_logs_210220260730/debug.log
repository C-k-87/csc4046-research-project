import math


def largest_prime_factor(n: int) -> int:

    largest_factor = -1


    # Divide n by 2 to handle even numbers

    while n % 2 == 0:

        largest_factor = 2

        n = n // 2


    # Handle odd numbers

    for i in range(3, int(math.sqrt(n)) + 1, 2):

        while n % i == 0:

            largest_factor = i

            n = n // i


    # If n is a prime number greater than 2

    if n > 2:

        largest_factor = n


    return largest_factor

```
