```python
from collections import OrderedDict

def int_to_mini_roman(number):
    val_map = OrderedDict({
        1000: 'M',
        900: 'CM',
        500: 'D',
        400: 'CD',
        100: 'C',
        90: 'XC',
        50: 'L',
        40: 'XL',
        10: 'X',
        9: 'IX',
        5: 'V',
        4: 'IV',
        1: 'I'
    })

    roman = ''

    for key in val_map:
        while number >= key:
            roman += val_map[key]
            number -= key

    return roman.lower()
```
