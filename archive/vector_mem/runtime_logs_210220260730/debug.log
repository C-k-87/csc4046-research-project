```python
from typing import List

def get_odd_collatz(n: int) -> List[int]:
    sequence = [n]
    while n != 1:
        if n % 2 == 0:
            n = n // 2
        else:
            n = n * 3 + 1
        sequence.append(n)

    odd_sequence = [num for num in sequence if num % 2 != 0]
    return sorted(odd_sequence)
```
