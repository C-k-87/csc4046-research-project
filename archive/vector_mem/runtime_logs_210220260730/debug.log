```python

from typing import List


def parse_nested_parens(paren_string: str) -> List[int]:
    def calculate_nesting_level(s: str, level: int) -> int:
        max_level = level
        current_level = 0
        for char in s:
            if char == '(':
                current_level += 1
                max_level = max(max_level, current_level)
            elif char == ')':
                current_level -= 1
        return max_level

    return [calculate_nesting_level(group, 1) for group in paren_string.split()]

```
