from typing import List


def minPath(grid: List[List[int]], k: int) -> List[int]:

    def dfs(i: int, j: int, path: List[int], visited: List[List[bool]]) -> List[int]:

        if len(path) == k:

            return path

        min_path = None

        for dx, dy in [(-1, 0), (1, 0), (0, -1), (0, 1)]:

            x, y = i + dx, j + dy

            if 0 <= x < len(grid) and 0 <= y < len(grid[0]) and not visited[x][y]:

                new_path = dfs(x, y, path + [grid[x][y]], visited)

                if not min_path or new_path < min_path:

                    min_path = new_path

        return min_path


    start = (0, 0)

    visited = [[False] * len(grid[0]) for _ in range(len(grid))]

    return dfs(start[0], start[1], [grid[start[0]][start[1]]], visited)

