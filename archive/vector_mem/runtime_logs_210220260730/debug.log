from typing import Union

def solve(N: int) -> str:
    if not isinstance(N, int) or N < 0 or N > 10000:
        raise ValueError("N must be a non-negative integer and not exceed 10000.")
    
    total_sum = 0
    while N:
        total_sum += N % 10
        N //= 10
    return bin(total_sum)[2:]
