def prod_signs(arr):
    if not arr:
        return None
    product_of_signs = reduce(lambda x, y: x * y, (1 if i > 0 else -1 if i < 0 else 0 for i in arr), 1)
    return sum(map(abs, arr)) * product_of_signs
