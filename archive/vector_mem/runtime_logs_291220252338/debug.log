```python
from typing import List, Tuple, Any

def get_row(lst: List[List[Any]], x: int) -> List[Tuple[int, int]]:
    result = []
    for i, row in enumerate(lst):
        for j, val in enumerate(row):
            if val == x:
                result.append((i, j))
    result.sort(key=lambda tup: (tup[0], -tup[1]))
    return result
```
