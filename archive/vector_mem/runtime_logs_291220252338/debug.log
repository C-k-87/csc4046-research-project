import string


def check_if_last_char_is_a_letter(txt):

    # check for empty string

    if not txt:

        return False


    # split the string into words using space as the delimiter

    words = txt.split()


    # get the last word in the list

    last_word = words[-1] if words else ''


    # check if the last character is in the alphabet and not part of a word

    return last_word and last_word[-1].isalpha() and not last_word[-1] in string.ascii_letters

