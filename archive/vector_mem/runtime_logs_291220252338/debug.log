from typing import List

def parse_music(music_string: str) -> List[int]:
    if music_string is None:
        return []
    if not music_string:
        return []
    beats = []
    note_lengths = {'o': 4, 'o|': 2, '.|': 1}
    for note in music_string.split():
        beats.append(note_lengths.get(note, 0))
    return beats
