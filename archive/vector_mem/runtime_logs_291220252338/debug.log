```python
def histogram(test):
    from collections import defaultdict
    
    if not test:
        return {}
    
    letter_count = defaultdict(int)
    
    for letter in test.split():
        letter_count[letter] += 1
    
    max_count = max(letter_count.values())
    result = {k:v for k, v in letter_count.items() if v == max_count}
    
    return result
```
