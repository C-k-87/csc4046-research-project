def closest_integer(value):
    from math import floor, ceil

    val = float(value)
    if val >= 0:
        return int(ceil(val)) if val - int(val) >= 0.5 else int(val)
    else:
        return int(floor(val)) if val - int(val) <= -0.5 else int(val)
