```python

import re


def vowels_count(s):
    """Return the number of vowels in the string.
    Vowels are 'a', 'e', 'i', 'o', 'u'.
    'y' is also a vowel when it is at the end of the word.
    """
    vowels = 'aeiou'
    y_at_end = r'\y$'
    vowels_with_y = vowels + 'y'
    count = len(re.findall(rf'[{vowels_with_y}]', s, re.IGNORECASE))
    if s.endswith('y'):
        count += 1
    return count

```

