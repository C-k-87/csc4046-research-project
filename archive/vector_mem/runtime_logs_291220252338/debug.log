import math


def max_fill(grid, capacity):

    def get_fill_count(row):

        fill_count = 0

        water_level = 0

        for cell in row:

            if cell == 1:

                water_level += capacity

                if water_level >= capacity:

                    water_level = 0

                    fill_count += 1

        return fill_count


