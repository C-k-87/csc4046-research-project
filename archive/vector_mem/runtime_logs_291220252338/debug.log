from typing import List


def rescale_to_unit(numbers: List[float]) -> List[float]:

    if not numbers or not all(isinstance(num, (float, int)) for num in numbers):

        return []


    min_val = min(numbers)

    max_val = max(numbers)


    if min_val == max_val:

        return [0.0]


    return [(num - min_val) / (max_val - min_val) for num in numbers]

```
