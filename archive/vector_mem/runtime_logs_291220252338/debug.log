from typing import List

def minPath(grid: List[List[int]], k: int) -> List[int]:
    N = len(grid)
    visited = [[False for _ in range(N)] for _ in range(N)]
    min_path = [float('inf')] * k

    def dfs(i: int, j: int, path: List[int], depth: int):
        nonlocal min_path
        if depth == k:
            min_path[0] = min(min_path[0], sum(path))
            return
        for x, y in [(i-1, j), (i+1, j), (i, j-1), (i, j+1)]:
            if 0 <= x < N and 0 <= y < N and not visited[x][y]:
                visited[x][y] = True
                dfs(x, y, path + [grid[x][y]], depth+1)
                visited[x][y] = False

    dfs(0, 0, [], 0)

    for i in range(N*N):
        min_path[0] = min(min_path[0], grid[i//N][i%N])

    min_path[0] = grid[0][0]
    for i in range(N*N):
        min_path.append(grid[i//N][i%N])

    min_path.sort()
    return min_path[k-1:k]
```
