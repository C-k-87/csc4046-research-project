from math import sqrt

def is_prime(n):
    if n < 2:
        return False
    for i in range(2, int(sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True

def is_multiply_prime(a):
    if a < 2 or a > 99:
        return False
    prime_factors = [i for i in range(2, a) if a % i == 0 and is_prime(i)]
    return len(prime_factors) == 3
