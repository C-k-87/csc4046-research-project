def match_parens(lst):
    from collections import deque

    if not lst or not isinstance(lst, (list, tuple)) or len(lst) != 2:
        return 'No'

    left_str, right_str = lst
    left_queue = deque(left_str)
    right_queue = deque(right_str)

    while left_queue and right_queue:
        left = left_queue.popleft()
        right = right_queue.pop()
        if left == '(' and right == ')':
            continue
        if left != '(':
            return 'No'
        right_queue.append(right)

    return 'Yes' if not left_queue and not right_queue else 'No'
