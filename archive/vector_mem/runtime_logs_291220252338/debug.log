from collections import deque

def reverse_delete(s, c):
    s_chars = deque(s)
    c_set = set(c)
    result_string = ''
    for char in s_chars:
        if char not in c_set:
            result_string += char
    is_palindrome = result_string == result_string[::-1]
    return result_string, is_palindrome
```
