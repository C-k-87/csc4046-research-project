from sympy import isprime

def even_odd_palindrome(n):
    even_palindromes = sum(1 for i in range(1, n + 1) if str(i) == str(i)[::-1] and i % 2 == 0)
    odd_palindromes = sum(1 for i in range(1, n + 1) if str(i) == str(i)[::-1] and i % 2 == 1)
    return (even_palindromes, odd_palindromes)
```
