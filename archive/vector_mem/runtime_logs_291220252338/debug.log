from math import floor

def get_odd_collatz(n):
    collatz_sequence = []
    while n != 1:
        collatz_sequence.append(n)
        if n % 2 == 0:
            n = n // 2
        else:
            n = 3 * n + 1
    collatz_sequence.append(n)

