from typing import List

def move_one_ball(arr: List[int]) -> bool:
    if not arr:
        return True

    target = sorted(arr)
    arr_length = len(arr)
    
    for _ in range(arr_length):
        if arr != target:
            return False
        arr = arr[-1:] + arr[:-1]
        
    return True
