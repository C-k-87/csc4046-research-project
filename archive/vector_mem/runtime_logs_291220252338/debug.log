```python
from collections import deque

def is_bored(S):
    count = 0
    sentences = deque(S.split('.?!'))
    while sentences:
        sentence = sentences.popleft()
        words = sentence.split()
        if words and words[0].lower() == 'i':
            count += 1
    return count
```
