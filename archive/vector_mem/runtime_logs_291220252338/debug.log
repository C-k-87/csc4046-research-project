```python

from collections import deque


def correct_bracketing(brackets: str) -> bool:

    open_brackets = deque()

    for bracket in brackets:

        if bracket == '<':

            open_brackets.append('>')

        elif bracket == '>' and open_brackets:

            open_brackets.popleft()

        else:

            return False

    return len(open_brackets) == 0

```
