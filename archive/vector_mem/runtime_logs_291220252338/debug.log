from typing import List

def monotonic(l: List[int]) -> bool:
    increasing = decreasing = True
    n = len(l)

    if n == 0:
        return True
    elif n == 1:
        return True

    for i in range(1, n):
        if l[i] < l[i - 1]:
            increasing = False
        if l[i] > l[i - 1]:
            decreasing = False

    return increasing or decreasing
```
