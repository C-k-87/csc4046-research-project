import re

def check_if_last_char_is_a_letter(txt):
    if txt == "":
        return False
    last_char = txt[-1]
    if not last_char.isalpha():
        return False
    words = re.findall(r'\b\w+\b', txt)
    if last_char in ' '.join(words):
        return False
    return True
```
