def change_base(x: int, base: int) -> str:

    digits = '0123456789ABCDEF'

    if base < 2 or base > 16:

        raise ValueError('Base must be between 2 and 16')

    if x < 0:

        raise ValueError('Number must be non-negative')

    if x == 0:

        return '0'

    result = ''

    while x > 0:

        result = digits[x % base] + result

        x //= base

    return result

```
