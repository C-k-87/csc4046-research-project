from typing import List

def words_string(s: str) -> List[str]:
    words = []
    word_start = 0
    for i, char in enumerate(s):
        if char in [',', ' ']:
            if word_start < i:
                words.append(s[word_start:i])
            word_start = i + 1
    if word_start < len(s):
        words.append(s[word_start:])
    return words
```
