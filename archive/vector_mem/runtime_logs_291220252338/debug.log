def decode_cyclic(s: str):
    # First, check if the string length is a multiple of 3.
    if len(s) % 3 != 0:
        return "Invalid input string for decoding"
    # Split the string into groups of 3.
    groups = [s[i:i+3] for i in range(0, len(s), 3)]
    # Cycle each group back to the original.
    decoded_groups = [(group[1] + group[2] + group[0]) for group in groups]
    # Join the groups back into a single string.
    return "".join(decoded_groups)
