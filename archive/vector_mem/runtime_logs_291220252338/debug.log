```python
from typing import Tuple

def fruit_distribution(s: str, n: int) -> int:
    apples, oranges = 0, 0
    for fruit_pair in s.split(' and '):
        count, fruit_type = fruit_pair.split()
        if fruit_type == 'apples':
            apples = int(count)
        elif fruit_type == 'oranges':
            oranges = int(count)
    return n - apples - oranges
```
