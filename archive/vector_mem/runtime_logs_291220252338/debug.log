from typing import List

def count_nums(arr: List[int]) -> int:
    def digit_sum(num: int) -> int:
        if num == 0:
            return 0
        elif num < 0:
            num = -num
        digit_sum_ = 0
        while num:
            digit_sum_ += num % 10
            num //= 10
        return digit_sum_

    count = 0
    for num in arr:
        if digit_sum(num) > 0:
            count += 1
    return count
```
