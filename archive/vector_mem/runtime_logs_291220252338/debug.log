from typing import List, Tuple

def pluck(arr: List[int]) -> List[int]:
    if not arr:
        return []

    min_even_index = -1
    min_even_value = float('inf')

    for i, num in enumerate(arr):
        if num % 2 == 0 and num < min_even_value:
            min_even_index = i
            min_even_value = num

    if min_even_index == -1:
        return []
    else:
        return [min_even_value, min_even_index]
```
