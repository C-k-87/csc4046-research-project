def is_equal_to_sum_even(n):
    if n % 2 != 0:
        return '0'

    def find_combinations(nums, target, start, combo, result):
        if target == 0 and len(combo) == 4:
            result.add(sum(combo))
            return
        for i in range(start, nums):
            if target - i < 0:
                break
            find_combinations(nums, target - i, i + 1, combo + [i], result)

    result = set()
    find_combinations(n, n, 2, [], result)
    return '1' if any(n in result for n in range(2, n + _n, 2)) else '0'
