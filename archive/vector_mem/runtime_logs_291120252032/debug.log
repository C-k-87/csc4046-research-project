from typing import List


def sort_numbers(numbers: str) -> str:

    valid_numbers = {'zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine'}


    if not isinstance(numbers, str):

        raise TypeError("Input must be a string.")


    number_words = numbers.split()

    if not all(word in valid_numbers for word in number_words):

        raise ValueError("Input contains invalid number words.")


    sorted_numbers = sorted(number_words, key=lambda word: valid_numbers.index(word))

    return ' '.join(sorted_numbers)

