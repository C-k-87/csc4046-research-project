from string import ascii_lowercase


def encrypt(s, shift=2):

    shifted_alphabet = ascii_lowercase[shift:] + ascii_lowercase[:shift]

    encrypted_text = ''

    for char in s:

        if char.isalpha():

            index = (ascii_lowercase.find(char) + shift) % len(ascii_lowercase)

            encrypted_text += shifted_alphabet[index]

        else:

            encrypted_text += char

    return encrypted_text

