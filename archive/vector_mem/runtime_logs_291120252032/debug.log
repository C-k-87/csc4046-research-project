def encode(message):
    vowels = 'aeiouAEIOU'
    shifted_alphabet = ''.join([chr((ord(c) - ord('a') + 2) % 26 + ord('a')) if c.isalpha() else c for c in 'abcdefghijklmnopqrstuvwxyz'])
