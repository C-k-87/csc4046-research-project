```python
from itertools import cycle

def int_to_mini_roman(number):
    roman_numerals = cycle(['I', 'V', 'X', 'L', 'C', 'D', 'M'])
    result = ''
    values = [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1]
    numerals = cycle(values)

    for value, numeral in zip(numerals, roman_numerals):
        while number >= value:
            result += numeral
            number -= value

    return result.lower()
```
