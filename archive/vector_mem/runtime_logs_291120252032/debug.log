from typing import List

def minPath(grid: List[List[int]], k: int) -> List[int]:
    N = len(grid)
    directions = [(-1, 0), (1, 0), (0, -1), (0, 1)]
    
    def dfs(x: int, y: int, visited: set, path: List[int]):
        if len(path) == k:
            return path
        if x < 0 or x >= N or y < 0 or y >= N or (x, y) in visited:
            return None
        visited.add((x, y))
        for dx, dy in directions:
            new_x, new_y = x + dx, y + dy
            new_path = dfs(new_x, new_y, visited, path + [grid[x][y]])
            if new_path is not None:
                return new_path
        visited.remove((x, y))
        return None

    min_path = None
    for i in range(N):
        for j in range(N):
            path = dfs(i, j, set(), [grid[i][j]])
            if path is not None and (min_path is None or path < min_path):
                min_path = path

    return min_path
