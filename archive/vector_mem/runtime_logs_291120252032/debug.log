```python
def get_odd_collatz(n):
    from math import ceil
    collatz_seq = []
    while n != 1:
        collatz_seq.append(n)
        if n % 2 == 0:
            n = n // 2
        else:
            n = 3 * n + 1
    if n == 1:
        collatz_seq.append(n)
    return sorted(set(filter(lambda x: x % 2 != 0, collatz_seq)))
```
