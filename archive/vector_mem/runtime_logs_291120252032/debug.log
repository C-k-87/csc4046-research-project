from collections import deque

def cycpattern_check(a, b):
    """Returns True if the second word or any of its rotations is a substring in the first word
    """
    if len(b) > len(a):
        return False

    b_seen = set()
    for i in range(len(a)):
        if a[i:i+len(b)] == b:
            return True
        b_seen.add(a[i:i+len(b)])

    for _ in range(len(a)):
        if b in b_seen:
            return True
        deque_a = deque(a)
        deque_a.rotate(-1)
        if ''.join(deque_a) == b:
            return True
        b_seen.add(''.join(deque_a))

    return False
```
