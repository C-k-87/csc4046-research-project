import string

def decode(secret_message, key):
    """Decodes a secret message encoded with a Vigenere cipher.

    Args:
        secret_message (str): The encoded secret message.
        key (str): The keyword used to encode the message.

    Returns:
        str: The decoded message.
    """

    alphabet = string.ascii_lowercase
    decoded_message = []
    key_index = 0

    for char in secret_message.lower():
        if char in alphabet:
            key_char = key[key_index % len(key)]
            key_index += 1
            key_index = alphabet.index(key_char)
            message_index = alphabet.index(char)
            decoded_index = (message_index - key_index) % 26
            decoded_char = alphabet[decoded_index]
            decoded_message.append(decoded_char)
        else:
            decoded_message.append(char)

    return ''.join(decoded_message)



