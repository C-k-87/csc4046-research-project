from collections import Counter


def even_odd_palindrome(n):
    even_count, odd_count = 0, 0
    
    for i in range(1, n+1):
        if str(i) == str(i)[::-1]:
            if i % 2 == 0:
                even_count += 1
            else:
                odd_count += 1
                
    return even_count, odd_count
```
