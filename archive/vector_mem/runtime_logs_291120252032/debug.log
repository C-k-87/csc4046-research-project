def f(n):
    from math import factorial

    def calc_even_index_value(i):
        return factorial(i)

    def calc_odd_index_value(i):
        return sum(range(1, i+1))

    result = [0] * n

    for i in range(1, n+1):
        result[i-1] = calc_even_index_value(i) if i % 2 == 0 else calc_odd_index_value(i)

    return result
```
