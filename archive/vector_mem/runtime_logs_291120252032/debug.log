def decode_cyclic(s: str):
    current_level = 0
    decoded_str = ""
    for char in s:
        if char == '(':
            current_level += 1
        elif char == ')':
            current_level -= 1
            if current_level < 0:
                raise ValueError("Invalid cyclic encoding")
        decoded_str += char
        if current_level == 0 and decoded_str[-2:] == "()":
            decoded_str = decoded_str[:-2]
    return decoded_str
```
