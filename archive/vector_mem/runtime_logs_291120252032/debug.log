from math import sqrt


def is_prime(num: int) -> bool:
    if num < 2:
        return False
    for i in range(2, int(sqrt(num))+1):
        if num % i == 0:
            return False
    return True


def prime_fib(n: int) -> int:
    a, b = 0, 1
    count = 0
    while count < n:
        if is_prime(b):
            count += 1
            if count == n:
                return b
        a, b = b, a + b
    return None

```
