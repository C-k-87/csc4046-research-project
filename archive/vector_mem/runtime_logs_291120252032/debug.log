        word_map = {

            0: "zero",

            1: "one",

            2: "two",

            3: "three",

            4: "four",

            5: "five",

            6: "six",

            7: "seven",

            8: "eight",

            9: "nine"

        }

        return "".join([word_map[int(digit)] for digit in str(num)])


    def string_to_number(s):

        return int("".join([str(word_map.get(char, char)) for char in s]))


    shift = shift % len(x)  # Handle cases where shift > length of the string


    if shift == 0:

        return x


    x_num = string_to_number(x)

    shifted_num = (x_num - 1) % (10 ** len(str(x_num))) + 1

    return number_to_string(shifted_num)


