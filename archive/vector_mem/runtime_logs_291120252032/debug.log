```python
from collections import deque

def match_parens(lst):
    def is_balanced(s):
        stack = deque()
        for c in s:
            if c == '(':
                stack.append(c)
            elif c == ')' and stack:
                stack.pop()
            else:
                return False
        return not stack

    def concatenate_and_check(s1, s2):
        return is_balanced(s1 + s2)

    for s1 in lst:
        for s2 in lst:
            if s1 != s2 and concatenate_and_check(s1, s2):
                return 'Yes'
    return 'No'
```
