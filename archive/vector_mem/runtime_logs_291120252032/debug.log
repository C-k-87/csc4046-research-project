import operator

def do_algebra(operator, operand):
    if not (isinstance(operator, list) and isinstance(operand, list) and len(operator) == len(operand) - 1):
        raise ValueError("Invalid arguments")

    result = operand[0]
    for i in range(1, len(operand)):
        if operator[i - 1] == '+':
            result += operand[i]
        elif operator[i - 1] == '-':
            result -= operand[i]
        elif operator[i - 1] == '*':
            result *= operand[i]
        elif operator[i - 1] == '//':
            result //= operand[i]
        elif operator[i - 1] == '**':
            result = operator.pow(result, operand[i])
        else:
            raise ValueError("Invalid operator")
    return result
```
