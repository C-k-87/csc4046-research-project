from collections import Counter

def total_match(lst1, lst2):
    char_count_lst1 = sum(map(len, lst1))
    char_count_lst2 = sum(map(len, lst2))
    
    if char_count_lst1 == char_count_lst2:
        return lst1
    
    return lst2 if char_count_lst2 < char_count_lst1 else lst1
```
