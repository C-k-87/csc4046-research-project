from collections import Counter


def smallest_change(arr):

    counts = Counter(arr)

    odd_values = [k for k, v in counts.items() if v % 2 == 1]

    even_values = [val for val in arr[::2] if val % 2 == 0]


    if len(odd_values) == 1:

        return 1


    changes_needed = 0


    for i in range(len(odd_values)):

        if odd_values[i] in even_values:

            even_values.remove(odd_values[i])

        else:

            changes_needed += 1


    for val in even_values:

        changes_needed += 1


    return changes_needed

```
