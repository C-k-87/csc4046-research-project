from typing import List

def exchange(lst1: List[int], lst2: List[int]) -> str:
    even_count_lst1, odd_count_lst1, even_count_lst2, odd_count_lst2 = 0, 0, 0, 0

    for num in lst1:
        if num % 2 == 0:
            even_count_lst1 += 1
        else:
            odd_count_lst1 += 1

    for num in lst2:
        if num % 2 == 0:
            even_count_lst2 += 1
        else:
            odd_count_lst2 += 1

    if even_count_lst1 == len(lst1) and odd_count_lst2 == len(lst2):
        return "YES"
    elif odd_count_lst2 == len(lst2):
        return "YES"
    else:
        return "NO"
```
