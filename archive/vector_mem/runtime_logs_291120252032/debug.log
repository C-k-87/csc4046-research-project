```python

import math


def largest_prime_factor(n: int):

    # Divide by 2 to remove all factors of 2

    while n % 2 == 0:

        largest = 2

        n = n // 2


    # Check for factors up to the square root of n

    for i in range(3, int(math.sqrt(n)) + 1, 2):

        while n % i == 0:

            largest = i

            n = n // i


    # If n is a prime number greater than 2

    if n > 2:

        largest = n


    return largest

```
