from typing import List

def minSubArraySum(nums: List[int]) -> int:
    current_sum = float('inf')
    min_sum = float('inf')
    
    for i in range(len(nums)):
        for j in range(i, len(nums)):
            current_sum = sum(nums[i:j+1])
            if current_sum < min_sum:
                min_sum = current_sum
    return min_sum
```
