def pluck(arr):
    if not arr:
        return []
    smallest_even = float('inf')
    index = -1
    for i, node in enumerate(arr):
        if node % 2 == 0 and node < smallest_even:
            smallest_even = node
            index = i
    if smallest_even == float('inf'):
        return []
    return [smallest_even, index]
```
