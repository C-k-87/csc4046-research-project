def fibfib(n: int):
    if n <= 2:
        return 0
    fib = [0] * (n + 1)
    fib[0] = 0
    fib[1] = 0
    for i in range(2, n + 1):
        fib[i] = fib[i - 1] + fib[i - 2] + fib[i - 3]
    return fib[n]
```
