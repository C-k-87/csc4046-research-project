def is_happy(s):
    if len(s) < 3:
        return False
    seen = set()
    for i in range(len(s) - 1):
        if s[i] in seen:
            return False
        seen.add(s[i])
        for j in range(len(s) - i - 1):
            if s[i + j + 1] == s[i] and s[i + j + 1] in seen:
                return False
    return True
```
