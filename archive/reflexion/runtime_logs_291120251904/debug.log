from typing import List

def unique_digits(x: List[int]) -> List[int]:
    def has_even_digit(n: int) -> bool:
        return any(digit % 2 == 0 for digit in map(int, str(n)))

    return sorted(set(n for n in x if not has_even_digit(n)))
