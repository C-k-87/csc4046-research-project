```python
from collections import deque

def will_it_fly(q, w):
    if len(q) < 2:
        return True
    
    q_deque = deque(q)
    half_len = len(q) // 2
    
    q_left = list(q_deque)[:half_len]
    q_right = list(q_deque)[half_len:]
    
    if sum(q_left) > w or sum(q_right) > w or q_left != q_right[::-1]:
        return False
    
    return sum(q) <= w
```
