def fix_spaces(text):
    count = 0
    result = []
    for char in text:
        if char == ' ':
            count += 1
            if count > 2:
                result.append('-')
            else:
                result.append('_')
        else:
            count = 0
            result.append(char)
    return ''.join(result)
