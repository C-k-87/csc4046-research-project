def encode(message):
    encoded_message = ""
    vowels = 'aeiou'
    for char in message:
        if char.isalpha():
            if char.lower() in vowels:
                encoded_char = chr(ord(char.lower()) + 2 if char.lower() + 2 < ord('z') else ord('a'))
            else:
                encoded_char = char.swapcase()
            encoded_message += encoded_char
        else:
            encoded_message += char
    return encoded_message
