import re

from datetime import datetime


def valid_date(date):

    if not date:

        return False


    pattern = r"^(0[1-9]|1[0-2])\-(0[1-9]|[12][0-9]|3[01])\-(19|20)\d\d$"

    match = re.match(pattern, date)

    if not match:

        return False


    month, day, year = map(int, date.split('-'))

    if month < 1 or month > 12:

        return False

    if day < 1 or (month in [4, 6, 9, 11] and day > 30):

        return False

    if month == 2:

        if day > 29:

            return False

        if (year % 4 == 0 and year % 100 != 0) or year % 400 == 0:

            if day > 28:

                return False

    return True

```

