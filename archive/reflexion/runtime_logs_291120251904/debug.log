def encrypt(s):
    shifted_alphabet = 'abcdefghijklmnopqrstuvwxyz'[-2:] + 'abcdefghijklmnopqrstuvwxyz'[:-2]
    encrypted_text = ''
    for char in s:
        if char.isalpha():
            shift = 2 if char.islower() else -2
            encrypted_char = shifted_alphabet[(shifted_alphabet.index(char) + shift) % 26]
            encrypted_text += encrypted_char
        else:
            encrypted_text += char
    return encrypted_text
