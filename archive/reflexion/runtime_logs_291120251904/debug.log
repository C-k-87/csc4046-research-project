```python

import math


def is_prime(n):
    if n <= 1:
        return False
    for i in range(2, int(math.sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True


def words_in_sentence(sentence):
    return ' '.join([word for word in sentence.split(' ') if is_prime(len(word))])

```
