from sympy import symbols, diff, simplify

def derivative(xs):
    x = symbols('x')
    polynomial = sum(xs[i] * x**(i + 1) for i in range(len(xs)))
    derivative = diff(polynomial, x).subs(x, 0)
    simplified_derivative = simplify(derivative)
    return [simplified_derivative.coeffs(x)]

