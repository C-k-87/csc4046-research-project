```python
from typing import List

def sorted_list_sum(lst: List[str]) -> List[str]:
    even_length_lst = [word for word in lst if len(word) % 2 == 0]
    even_length_lst.sort(key=lambda x: (len(x), x))
    return even_length_lst
```
