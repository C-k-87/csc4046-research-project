```python

def change_base(x: int, base: int):
    if base < 2 or base > 10:
        raise ValueError("Base must be less than 10 and greater than 1.")
    if x < 0:
        raise ValueError("Number must be non-negative.")
    
    digits = "0123456789"
    if base == 10:
        return str(x)
    
    result = ''
    while x > 0:
        remainder = x % base
        result = digits[remainder] + result
        x //= base
    return result

```
