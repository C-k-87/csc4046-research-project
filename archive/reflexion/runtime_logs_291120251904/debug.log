def make_a_pile(n):
    pile = [n]
    next_odd = n - 1 if n % 2 == 0 else n - _2
    next_even = n - 2 if n % 2 == 0 else n - 1
    while next_odd > 0:
        pile.append(next_odd)
        if next_odd % 2 == 0:
            next_even = next_even - 2
        next_odd = next_odd - 2
    return pile
```
