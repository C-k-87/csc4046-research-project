def get_odd_collatz(n):
    sequence = []
    while n != 1:
        sequence.append(n)
        if n % 2 == 0:
            n = n // 2
        else:
            n = 3 * n + 1
    odd_numbers = [num for num in sequence if num % 2 != 0]
    return sorted(odd_numbers)
```
