def find_max(words):

    def count_unique_chars(word):

        return len(set(word))


    max_word = ""

    max_count = 0

    for word in words:

        unique_chars_count = count_unique_chars(word)

        if unique_chars_count > max_count or (unique_chars_count == max_count and word < max_word):

