from math import sqrt


def is_prime(num):
    if num < 2:
        return False
    for i in range(2, int(sqrt(num)) + 1):
        if num % i == 0:
            return False
    return True


def prime_fib(n: int) -> int:
    a, b = 0, 1
    count = 0
    while True:
        fib = a + b
        a, b = b, fib
        if is_prime(fib):
            count += 1
            if count == n:
                return fib

```
