```python
from typing import List

def get_odd_collatz(n: int) -> List[int]:
    sequence = []
    while n != 1:
        sequence.append(n)
        if n % 2 == 0:
            n = n // 2
        else:
            n = 3 * n + 1
    sequence.append(1)

    return sorted(filter(lambda x: x % 2 != 0, sequence))
```
