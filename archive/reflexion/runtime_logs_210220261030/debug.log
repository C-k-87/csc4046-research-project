def get_max_triples(n):
    from collections import Counter

    def a_value(i):
        return i * i - i + 1

    a = [a_value(i) for i in range(1, n + 1)]
    triple_counts = Counter((x + y, z) for i, x in enumerate(a) for j, y in enumerate(a) for k, z in enumerate(a) if i < j < k)

    return sum(v for k, v in triple_counts.items() if (k % 3 == 0))
```

