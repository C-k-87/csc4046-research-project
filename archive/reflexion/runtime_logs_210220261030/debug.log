def change_base(x: int, base: int) -> str:
    if not 2 <= base < 11:
        raise ValueError('Base must be less than 10 and greater than 1.')

    num_in_base_10 = x
    result = ''
    while num_in_base_10 > 0:
        remainder = num_in_base_10 % base
        result = str(remainder) + result
        num_in_base_10 //= base
    return result
```
