from math import sqrt

def is_prime(n):
    if n <= 1:
        return False
    for i in range(2, int(sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True

def count_up_to(n):
    primes = []
    current = 2
    while len(primes) < n:
        if is_prime(current):
            primes.append(current)
        current += 1
    return primes
