from functools import reduce

def solve(N):
    if not isinstance(N, int) or N < 0 or N > 10000:
        raise ValueError("N must be a positive integer between 0 and 10000.")
    
    digit_sum = reduce(lambda x, y: x + y, map(int, str(N)))
    binary_string = "{0:b}".format(digit_sum)
    return binary_string
```
