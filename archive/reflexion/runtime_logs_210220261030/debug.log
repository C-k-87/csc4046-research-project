from collections import deque

def minPath(grid, k):
    N = len(grid)
    visited = [[False]*N for _ in range(N)]
    min_path = float('inf')
    min_path_lst = []
    
    def dfs(i, j, path_len, visited, grid):
        if path_len == k:
            if len(path_lst) < min_path:
                min_path = len(path_lst)
                min_path_lst = path_lst.copy()
            return
        if not (0 <= i < N and 0 <= j < N) or visited[i][j]:
            return
        
        path_lst.append(grid[i][j])
        visited[i][j] = True
        
        for di, dj in [(-1, 0), (1, 0), (0, -1), (0, 1)]:
            ni, nj = i + di, j + dj
            dfs(ni, nj, path_len + 1, visited, grid)
        
        visited[i][j] = False
        path_lst.pop()
    
    for i in range(N):
        for j in range(N):
            dfs(i, j, 1, visited, grid)
    
    return min_path_lst
