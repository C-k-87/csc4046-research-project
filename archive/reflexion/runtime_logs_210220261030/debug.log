from typing import List


def separate_paren_groups(paren_string: str) -> List[str]:
    stack = []
    result = []
    paren_string = ''.join(paren_string.split())  # Remove spaces
    for char in paren_string:
        if char == '(':
            stack.append('')
        elif char == ')' and stack:
            result.append(stack.pop() + char)
        else:
            continue
    return result
```
