import string

def file_name_check(file_name):
    if '.' not in file_name or len(file_name.split('.')) != 2:
        return 'No'

    parts = file_name.split('.')
    if sum(c.isdigit() for c in parts[0]) > 3:
        return 'No'
    if not parts[0][0] in string.ascii_letters:
        return 'No'
    if parts[1] not in ['txt', 'exe', 'dll']:
        return 'No'
    
    return 'Yes'
```
