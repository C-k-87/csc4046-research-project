from operator import add, sub, mul, truediv, pow

def do_algebra(operator, operand):
    result = operand[0]
    for i in range(len(operator)):
        if operator[i] == '+':
            result = add(result, operand[i+1])
        elif operator[i] == '-':
            result = sub(result, operand[i+1])
        elif operator[i] == '*':
            result = mul(result, operand[i+1])
        elif operator[i] == '//':
            result = truediv(result, operand[i+1])
        elif operator[i] == '**':
            result = pow(result, operand[i+1])
    return result
```
