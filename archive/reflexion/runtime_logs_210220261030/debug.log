```python
from string import ascii_letters

def select_words(s: str, n: int) -> list[str]:
    if not s:
        return []

    words = s.split()
    result = []

    for word in words:
        count = sum(1 for char in word if char in ascii_letters and char not in 'aeiouAEIOU')
        if count == n:
            result.append(word)

    return result
```
