def move_one_ball(arr):
    if not arr:
        return True
    min_index = arr.index(min(arr))
    if min_index == len(arr) - 1:
        return True
    for _ in range(min_index):
        arr.insert(0, arr.pop())
    for i in range(len(arr) - 1):
        if arr[i] > arr[i + 1]:
            return False
    return True
```
