import math

def poly(xs: list, x: float):
    return sum([coeff * math.pow(x, i) for i, coeff in enumerate(xs)])

def find_zero(xs: list):
    if len(xs) % 2 != 0:
        raise ValueError("List must have even number of coefficients")
    
    largest_non_zero_index = len(xs) // 2 - 1
    if xs[largest_non_zero_index] == 0:
        raise ValueError("List must have non-zero largest coefficient")

    if largest_non_zero_index < 0:
        return 0.0

    left, right = xs[largest_non_zero_index], xs[largest_non_zero_index]
    midpoint = (left + right) / 2.0

    while abs(poly(xs, midpoint)) > 1e-10:
        if poly(xs, midpoint) > 0:
            right = midpoint
        else:
            left = midpoint
        
        midpoint = (left + right) / 2.0

    return midpoint
```
