def tri(n):
    if n == 0:
        return [3]
    if n == 1:
        return [3, 1]
    seq = [3, 1, 3]
    for i in range(3, n+1):
        if i % 2 == 0:
            seq.append(1 + i // 2)
        else:
            seq.append(seq[-1] + seq[-2] + seq[-3])
    return seq[:n+1]
```
