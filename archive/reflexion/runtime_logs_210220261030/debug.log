def by_length(arr):

    def is_valid_digit(n):

        return 1 <= n <= 9


    def convert_to_name(n):

        digit_names = {

            1: "One",

            2: "Two",

            3: "Three",

            4: "Four",

            5: "Five",

            6: "Six",

            7: "Seven",

            8: "Eight",

            9: "Nine"

        }

        return digit_names.get(n, "")


    filtered_arr = [str(x) for x in arr if is_valid_digit(x)]

    filtered_arr.sort()

    filtered_arr.reverse()

    return [convert_to_name(int(digit)) for digit in filtered_arr]

