from typing import List

def factorize(n: int) -> List[int]:
    factors = []
    div = 2
    while n > 1:
        count = 0
        while n % div == 0:
            n //= div
            count += 1
        if count > 0:
            factors.extend([div] * count)
        div += 1
        if div*div > n:
            if n > 1:
                factors.append(n)
                break
    return factors
```
