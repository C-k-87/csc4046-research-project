import string

def encode(message):
    if not isinstance(message, str):
        raise ValueError("Input must be a string")
    result = []
    for char in message:
        if char.isalpha():
            if char.isupper():
                result.append(char.lower())
            else:
                result.append(char.upper())
            if char in 'aeiou':
                new_char = chr(ord(char) + 2)
                if new_char.lower() in 'aeiou':
