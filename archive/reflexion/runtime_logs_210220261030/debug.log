from math import ceil

def is_equal_to_sum_even(n):
    # Base case: if n is odd, it can't be written as the sum of 4 even numbers
    if n % 2 != 0:
        return False

    # Try all possible combinations of 4 even numbers whose sum is n
    for a in range(ceil(n / 2), 0, -2):
        for b in range(ceil(n / 4), 0, -2):
            for c in range(ceil(n / 8), 0, -2):
                for d in range(ceil(n / 16), 0, -2):
                    if a + b + c + d == n:
                        return True

    return False
