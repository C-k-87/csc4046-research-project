```python

import string


def encode(message):

    def is_vowel(char):

        return char.lower() in 'aeiou'


    def shift_char(char):

        if char.isalpha():

            shift = ord(char.lower()) + 2

            if shift > ord('z'):

                shift -= 26

            return chr(shift)

        return char


    encoded_message = ''

    for char in message:

        if is_vowel(char):

            encoded_message += shift_char(char)

        else:

            encoded_message += shift_char(char).swapcase()

    return encoded_message


```
