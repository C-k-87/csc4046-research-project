def tri(n):
    """Returns a list of the first n+1 numbers of the Tribonacci sequence."""
    if n < 1:
        return []
    seq = [0] * (n + 2)
    seq[1] = 3
    if n % 2 == 0:
        seq[n+1] = 1 + n // 2
    else:
        for i in range(3, n + 2):
            seq[i] = seq[i - 2] // 2 + seq[i - 1] + seq[i + 1]
    return seq[:n+1]
```
