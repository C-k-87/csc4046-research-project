def encode(message):
    encoded_message = ''
    for char in message:
        if char.isalpha():
            if char in 'aeiouAEIOU':
                shifted_char = chr((ord(char) + 2) % 26 + ord('A')) 
            else:
                shifted_char = chr(ord(char) ^ 2)
            encoded_message += shifted_char
        else:
            encoded_message += char
    return encoded_message
