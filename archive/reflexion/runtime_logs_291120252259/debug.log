def int_to_mini_roman(number):
    roman_values = ['M', 'CM', 'D', 'CD', 'C', 'XC', 'L', 'XL', 'X', 'IX', 'V', 'IV', 'I']
    int_values = [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1]
    roman_number = ''
    i = 0
    while number > 0:
        while number >= int_values[i]:
            number -= int_values[i]
            roman_number += roman_values[i]
        i += 1
    return roman_number.lower()
```
