def by_length(arr):
    if len(arr) == 0:
      return []
    sorted_arr = sorted(arr)
    reversed_arr = sorted_arr[::-1]
    result = []
    for num in reversed_arr:
      if 1 <= int(num) <= 9:
        result.append(
            "One" if int(num) == 1 else 
            "Two" if int(num) == 2 else
            "Three" if int(num) == 3 else
            "Four" if int(num) == 4 else
            "Five" if int(num) == 5 else
            "Six" if int(num) == 6 else
            "Seven" if int(num) == 7 else
            "Eight" if int(num) == 8 else
            "Nine"
        )
    return result
