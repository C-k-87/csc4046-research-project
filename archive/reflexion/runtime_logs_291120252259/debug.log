def is_palindrome(string: str) -> bool:
    return string == string[::-1]


def make_palindrome(string: str) -> str:
    if len(string) == 0:
        return string
    l, r = 0, len(string) - 1
    palindrome_suffix = ''
    while l < r:
        if string[l] != string[r]:
            palindrome_suffix = string[l : r+1]
            break
        l += 1
        r -= 1
    return string[:l] + palindrome_suffix + string[r+1:]
```
