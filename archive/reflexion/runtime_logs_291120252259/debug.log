def minSubArraySum(nums):
    min_sum = float('inf')
    for start in range(len(nums)):
        current_sum = 0
        for i in range(start, len(nums)):
            current_sum += nums[i]
            min_sum = min(min_sum, current_sum)
    return min_sum
