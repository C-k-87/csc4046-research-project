import re

def parse_music(music_string: str) -> List[int]:
    beats = []
    notes = re.findall(r'[o|\.]+', music_string)
    for note in notes:
        if note == 'o':
            beats.append(4)
        elif note == 'o|':
            beats.append(2)
        else:
            beats.append(1)
    return beats
