import re


def is_bored(S):
    """
    You'll be given a string of words, and your task is to count the number
    of boredoms. A boredom is a sentence that starts with the word "I".
    Sentences are delimited by '.', '?' or '!'.
    """
    # Split the string into sentences using a more refined regex pattern
    # to avoid splitting abbreviations or numbers
    sentences = re.split(r"([.!?]\s*(?<!\w\.\w))", S)
    
    # Filter for non-empty sentences and count those starting with "I"
    boredom_count = sum(1 for sentence in sentences if sentence.strip().startswith('I'))
    
    return boredom_count
```
