    sentences = re.split(r"[.!?]", S)
    
    # Count boredoms by filtering for sentences starting with "I" and non-empty
    boredom_count = sum(1 for sentence in sentences if sentence and sentence.strip().startswith('I'))
    
    return boredom_count
