from typing import List
import heapq

def maximum(arr: List[int], k: int) -> List[int]:
    if not arr:
        return []
    heap = arr[:k]
    heapq.heapify(heap)
    for element in arr[k:]:
        if element > heap[0]:
            heapq.heapreplace(heap, element)
    return heap

