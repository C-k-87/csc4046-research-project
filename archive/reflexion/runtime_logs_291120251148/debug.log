def minSubArraySum(nums):
    min_sum = float('inf')
    current_sum = 0
    
    start = 0
    for end in range(len(nums)):
        current_sum += nums[end]

        while current_sum >= min_sum:
            min_sum = min(min_sum, current_sum - nums[start])
            current_sum -= nums[start]
            start += 1

    return min_sum if min_sum != float('inf') else None
