from math import sqrt


def is_prime(n):
    if n < 2:
        return False
    for i in range(2, int(sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True


def count_up_to(n):
    primes = []
    current_num = 2
    while len(primes) < n and current_num < n:
        if is_prime(current_num):
            primes.append(current_num)
        current_num += 1
    return primes
```
