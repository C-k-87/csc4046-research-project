from typing import List

def monotonic(l: List[int]) -> bool:
    is_increasing = True
    is_decreasing = True
    for i in range(1, len(l)):
        if l[i-1] < l[i]:
            is_decreasing = False
        elif l[i-1] > l[i]:
            is_increasing = False

    return is_increasing or is_decreasing
