from functools import reduce


def prod_signs(arr):
    if not arr:
        return None
    
    product_of_signs = reduce(lambda x, y: x * y, map(lambda x: 1 if x > 0 else -1 if x < 0 else 0, arr), 1)
    
    sum_of_magnitudes = sum(map(abs, arr))

    return product_of_signs * sum_of_magnitudes

