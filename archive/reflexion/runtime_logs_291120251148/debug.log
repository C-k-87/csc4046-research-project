from typing import Any


def check_dict_case(dict_: dict) -> bool:
    if not dict_:
        return False

    lowercase_keys = all(isinstance(key, str) and key.islower() for key in dict_.keys())
    uppercase_keys = all(isinstance(key, str) and key.isupper() for key in dict_.keys())

    return lowercase_keys or uppercase_keys

```
