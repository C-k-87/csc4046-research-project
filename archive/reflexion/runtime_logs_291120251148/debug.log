from typing import List

def specialFilter(nums: List[int]) -> int:
    count = 0
    for num in nums:
        if num > 10 and int(str(abs(num))[0]) % 2 != 0 and int(str(abs(num))[-1]) % 2 != 0:
            count += 1
    return count
```


