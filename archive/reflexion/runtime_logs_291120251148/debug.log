```python

from collections import deque


def correct_bracketing(brackets: str) -> bool:
    bracket_stack = deque()
    for bracket in brackets:
        if bracket == '(':
            bracket_stack.append(bracket)
        elif bracket == ')' and bracket_stack and bracket_stack[-1] == '(':
            bracket_stack.pop()
        else:
            return False
    return not bracket_stack
```
