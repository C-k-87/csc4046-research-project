def get_closest_vowel(word):
    vowels = 'aeiouAEIOU'
    word_len = len(word)
    for i in range(word_len - 1, -1, -1):
        if word[i] in vowels:
            if i < word_len - 1 and word[i + 1] not in vowels:
                return word[i]
            elif i == 0 or (i > 0 and word[i - 1] not in vowels):
                return word[i]
    return ""
