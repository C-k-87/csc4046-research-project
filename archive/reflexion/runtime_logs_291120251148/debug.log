        return False
    for i in range(2, int(math.sqrt(n)) + e1):
        if n % i == 0:
            return False
    return True


def is_multiply_prime(a):
    if a < 4:  # A number with fewer than 3 factors can't be 'multiply prime'
        return False
    factors = set()
    for i in range(2, math.isqrt(a) + 1):  # Using math.isqrt for better performance
        if a % i == 0:
            factors.add(i)
            factors.add(a // i)
            if len(factors) > 2:
                return False
    return len(factors) == 2


