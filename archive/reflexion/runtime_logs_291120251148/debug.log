import math


def is_simple_power(x, n):
    # Check if x is a positive integer
    if not isinstance(x, int) or x < 1:
        return False

    # Check if n is a positive integer
    if not isinstance(n, int) or n < 1:
        return False

    # Check if x is a power of n
    if x == 1 and n == 1:
        return True

    # If x and n are both 1, x is a power of n
    if x == 1:
        return True

    # If x is 1, n should be 1
    if x == n:
        return True

    # If n is 1, x can be any positive integer
    if n == 1:
        return True

    # Check if x is a power of n
    if x % n == 0:
        return is_simple_power(x // n, n)

    return False

```
