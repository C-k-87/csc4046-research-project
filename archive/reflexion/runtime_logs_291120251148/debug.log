from typing import List


def separate_paren_groups(paren_string: str) -> List[str]:
    stack = []
    result = []
    for char in paren_string:
        if char == '(':
            stack.append('')
        elif char == ')' and stack:
            result.append(''.join(stack))
            stack = stack[:-1] # Remove the last element from the stack
    return result

