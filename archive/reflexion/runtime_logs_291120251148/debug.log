def smallest_change(arr):
    n = len(arr)
    count = [0]*n
    
    for i in range(n//2):
        count[i] = abs(arr[i] - arr[n-i-1])
    
    changes = sum(count) // 2
    
    for i in range(n//2-1):
        if count[i] == count[i+1]:
            changes -= 1
            
    return changes
```


