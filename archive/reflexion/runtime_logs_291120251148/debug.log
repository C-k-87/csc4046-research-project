def is_equal_to_sum_even(n):
    for i in range(2, int(n/2)+1, 2):
        if n - i <= 0:
            continue
        for j in range(i, int((n - i)/2)+1, 2):
            if n - i - j <= 0:
                continue
            for k in range(j, int((n - i - j)/2)+1, 2):
                if n - i - j - k <= 0:
                    continue
                if (n - i - j - k) % 2 == 0:
                    return True
    return False
