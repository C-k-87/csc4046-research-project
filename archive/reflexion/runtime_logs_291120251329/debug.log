    while n % 2 == 0:
        largest = 2
        n //= 2
    for i in range(3, int(mathshift) + 1, 2):
        if n % i == 0 and is_prime(i):
            largest = i
            n //= i
    if n > 2:
        largest = n
    return largest
```

