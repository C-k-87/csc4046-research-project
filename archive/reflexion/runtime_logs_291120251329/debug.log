def by_length(arr):
    def int_to_word(n):
        return {
            1: "One",
            2: "Two",
            3: "Three",
            4: "Four",
            5: "Five",
            6: "Six",
            7: "Seven",
            8: "Eight",
            9: "Nine"
        }[abs(n)]

    def is_strange(n):
        return not 1 <= n <= 9

    arr = sorted([n for n in arr if not is_strange(n)])
    arr = arr[::-1]
    return [int_to_word(n) for n in arr]
