def change_base(x: int, base: int) -> str:

    if base < 2 or base > 10:

        raise ValueError("Base must be between 2 and 10.")


    if x == 0:

        return "0"


    digits = "0123456789ABCDEFGHIJ"

    result = ""


    while x > 0:

        digit = x % base

        result = digits[digit] + result

        x = x // base


    return result

```
