```python
from typing import List

def factorize(n: int) -> List[int]:
    factors = []
    div = 2
    while n > 1:
        while n % div == 0:
            factors.append(div)
            n /= div
        div += 1
        if div**2 > n:
            if n > 1:
                factors.append(n)
                break
    return factors
```
