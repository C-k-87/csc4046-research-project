import math

def right_angle_triangle(a, b, c):
    # Sort the sides
    sides = sorted([a, b, c])

    # Check if the sum of the squares of the two shorter sides is equal to the square of the longest side
    return math.isclose(sides[0] ** 2 + sides[1] ** 2, sides[2] ** 2, rel_tol=1e-9)
