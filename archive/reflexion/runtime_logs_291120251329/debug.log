```python
from functools import lru_cache

def fib4(n: int) -> int:
    @lru_cache(maxsize=None)
    def fib4_helper(n: int) -> int:
        if n == 0:
            return 0
        elif n == 1:
            return 0
        elif n == 2:
            return 2
        elif n == 3:
            return 0
        else:
            return fib4_helper(n-1) + fib4_helper(n-2) + fib4_helper(n-3) + fib4_helper(n-4)

    return fib4_helper(n)
```
