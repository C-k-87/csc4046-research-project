```python
import cmath

def iscube(a):
    '''
    Write a function that takes an integer a and returns True 
    if this integer is a cube of some integer number.
    Note: you may assume the input is always valid.
    Examples:
    iscube(1) ==> True
    iscube(2) ==> False
    iscube(-1) ==> True
    iscube(64) ==> True
    iscube(0) ==> True
    iscube(180) ==> False
    '''
    if isinstance(a, complex):
        return False
    cube_root = cmath.cbrt(a)
    return cube_root.is_integer() and int(cube_root)**3 == a
```
