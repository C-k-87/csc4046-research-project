from typing import List


def monotonic(l: List[int]) -> bool:
    increasing = decreasing = True

    for i in range(len(l) - 1):
        if l[i] > l[i+1]:
            increasing = False
        elif l[i] < l[i+1]:
            decreasing = False

    return increasing or decreasing

```
