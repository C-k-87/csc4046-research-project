from collections import Counter

def is_happy(s):
    if len(s) < 3:
        return False
    counter = Counter()
    for i in range(len(s) - 2):
        triplet = s[i:i+3]
        counter[triplet] += 1
    return all(val == 1 for val in counter.values())
```
