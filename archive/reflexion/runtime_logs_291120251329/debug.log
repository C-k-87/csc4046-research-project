def eat(number, need, remaining):
    if not (0 <= number <= 1000) or not (0 <= need <= 1e3) or not (0 <= remaining <= 1e3):
        raise ValueError("Input values must be within the range 0 to 1000.")
    
    total_eaten = number + min(need, remaining)
    leftover = max(0, remaining - need)
    return [total_eaten, leftover]
