from collections import Counter

def same_chars(s0: str, s1: str) -> bool:
    """
    This function returns True if both strings have the same characters
    (irrespective of order) and False otherwise.
    """
    return Counter(s0) == Counter(s1)


# Unit tests:

def test_same_chars():
    assert same_chars('aabbcc', 'ccbbaa') == True
    assert same_chars('aabbcc', 'ddeeff') == False
    assert same_chars('', '') == True
    assert same_chars('abc', '') == False
    assert same_chars('abc', 'ab') == False
    assert same_chars('hello', 'world') == False
    print('All tests passed!')

