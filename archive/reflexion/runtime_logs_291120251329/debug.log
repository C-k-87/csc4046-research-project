from collections import Counter

def total_match(lst1, lst2):
    char_count1 = sum(map(len, lst1))
    char_count2 = sum(map(len, lst2))

    if char_count1 == char_count2:
        return lst1
    elif char_count1 < char_count2:
        return lst1
    else:
        return lst2
```
