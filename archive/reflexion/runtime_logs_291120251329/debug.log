def fruit_distribution(s: str, n: int) -> int:
    fruits = s.split(" and ")
    apple_count = int(fruits[0].split(" ")[0])
    orange_count = int(fruits[1].split(" ")[0])
    mango_count = n - apple_count - orange_count
    return mango_count
