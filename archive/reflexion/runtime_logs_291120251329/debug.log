import locale


def compare_one(a, b):
    locale.setlocale(locale.LC_ALL, 'en_US.UTF-8')

    a_float = locale.atof(a) if ',' in a else float(a)
    b_float = locale.atof(b) if ',' in b else float(b)

    if a_float == b_float:
        return None
    return max(a_float, b_float)

```
