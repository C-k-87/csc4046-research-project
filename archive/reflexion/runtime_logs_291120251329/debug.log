from typing import List, Optional

def next_smallest(lst: List[int]) -> Optional[int]:
    if len(lst) < 2:
        return None

    first, second = float('inf'), float('inf')
    for x in lst:
        if x < first:
            first, second = x, first
        elif first < x < second:
            second = x
    return second if second != float('inf') else None
```
