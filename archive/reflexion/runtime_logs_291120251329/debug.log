```python

def skjkasdkd(lst):
    import math

    def is_prime(n):
        if n < 2:
            return False
        for i in range(2, int(math.sqrt(n)) + 1):
            if n % i == 0:
                return False
        return True

    def digit_sum(n):
        return sum(int(digit) for digit in str(n))

    max_prime = None
    for num in lst:
        if is_prime(num):
            if max_prime is None or num > max_prime:
                max_prime = num

    return digit_sum(max_prime) if max_prime else 0

