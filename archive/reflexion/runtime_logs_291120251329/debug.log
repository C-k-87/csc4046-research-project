def find_max(words):

    max_word = ''

    max_count = 0

    for word in sorted(words):

        unique_chars = set(word)

        if len(unique_chars) > max_count or (len(unique_chars) == max_count and word < max_word):

            max_word = word

            max_count = len(unique_chars)

    return max_word

