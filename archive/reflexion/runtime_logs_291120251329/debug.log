def minPath(grid, k):
    N = len(grid)
    visited = [[False for _ in range(N)] for _ in range(N)]
    min_path = []

    def is_valid_move(x, y):
        return 0 <= x < N and 0 <= y < N and not visited[x][y]

    def dfs(x, y, path):
        nonlocal min_path
        visited[x][y] = True
        path.append(grid[x][y])
