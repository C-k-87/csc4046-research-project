def even_odd_palindrome(n):
    from collections import Counter
    
    def is_palindrome(x):
        return str(x) == str(x)[::-1]
    
    even_odd_counts = Counter()
    for i in range(1, n + 1):
        if is_palindrome(i):
            even_odd_counts[i % 2] += 1
    
    return even_odd_counts[0], even_odd_counts[1]
```
