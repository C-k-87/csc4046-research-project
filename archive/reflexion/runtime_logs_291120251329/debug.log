import math

def closest_integer(value):
    if value.startswith('-') and '.' in value:
        number = float(value)
    else:
        number = float(value)
    
    left = math.floor(number)
    right = math.ceil(number)
    
    if number - left == 0.5 and number > 0 or number - right == -0.5:
        return right if number > 0 else left
    else:
        return left if number < 0 else right
```
